// Saishubh Holidays — Prisma Schema (MongoDB)
// The environment provides MongoDB via MONGO_URL. Prisma supports MongoDB natively.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  username     String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model TourPackage {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String   @unique
  category          String   // Domestic | International | Pilgrimage
  duration          String
  startingLocation  String
  bestTimeToVisit   String
  highlights        Json
  itinerary         Json
  inclusions        Json
  exclusions        Json
  gallery           Json
  mapUrl            String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Enquiry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String
  email       String?
  message     String?
  packageName String?
  travelDate  String?
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  rating    Int      @default(5)
  message   String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Gallery {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  category  String?
  createdAt DateTime @default(now())
}
